# ── LLM Provider ──────────────────────────────────────────────────────────────
# Required: choose one provider and supply its key.
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-opus-4-7       # e.g. claude-opus-4-7, claude-sonnet-4-6, gpt-4o

ANTHROPIC_API_KEY=sk-ant-...    # required if LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-...           # required if LLM_PROVIDER=openai

# ── Encryption (Phase 5+) ─────────────────────────────────────────────────────
# Master key used to encrypt secrets stored in swarm.db.
#
# Resolution order on boot:
#   1. SWARM_ENCRYPTION_KEY env var (this file) — wins if set
#   2. <DATA_DIR>/.encryption_key file — read if env var is empty
#   3. If neither exists, the container generates a key on first boot and
#      writes it to <DATA_DIR>/.encryption_key (logged on stderr)
#
# Leave empty for "just works" mode (recommended for single-host deployments
# where the data volume is your source of truth). Set explicitly when you
# want to manage the key out-of-band — e.g. via a secret manager — and not
# store it next to the encrypted database.
#
# To generate one yourself:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# ⚠️  Losing this key makes encrypted settings unrecoverable. If you let the
#     container generate it, back up <DATA_DIR>/.encryption_key alongside
#     swarm.db (or, ideally, separately from your routine data backups).
SWARM_ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to SQLite at /data/swarm.db (inside the container volume).
DATABASE_URL=sqlite:////data/swarm.db

# ── File paths ────────────────────────────────────────────────────────────────
DATA_DIR=/data

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/Amsterdam

# ── External services (used by example skills — not required by the platform) ─
# ERP skill
ERP_API_URL=
ERP_API_TOKEN=

# Email skill
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=swarm@example.com

# Microsoft Graph (finance mailbox heartbeat)
GRAPH_API_TOKEN=
FINANCE_MAILBOX=Finance@example.com
